HECATEAPI_LISTEN_ADDR=:9090
HECATEAPI_LEDGER_ADDR=ledger:50051
HECATEAPI_LEDGER_INSECURE=true
HECATEAPI_LEDGER_TIMEOUT=3s
HECATEAPI_DEFAULT_TENANT_ID=default
HECATEAPI_DEFAULT_LEDGER_ID=default
HECATEAPI_ALLOWED_ORIGINS=http://localhost:8000
HECATEAPI_JWT_SIGNING_KEY=<base64-encoded-key-must-match-tauth>
HECATEAPI_JWT_ISSUER=tauth
HECATEAPI_JWT_COOKIE_NAME=app_session
HECATEAPI_TAUTH_BASE_URL=http://tauth:8080
HECATEAPI_LLM_PROXY_URL=https://llm-proxy.mprlab.com
HECATEAPI_LLM_PROXY_KEY=<llm-proxy-service-secret>
HECATEAPI_LLM_PROXY_TIMEOUT=30s
# Keep admin emails in env, not config.yaml, because config.yaml is client-readable.
HECATEAPI_ADMIN_EMAILS=admin@example.com

# Billing (Paddle credit packs)
# Use Paddle price IDs here, not Paddle product IDs.
# One price ID is required per pack code in configs/config.yml.
HECATEAPI_BILLING_PROVIDER=paddle
HECATEAPI_PADDLE_ENVIRONMENT=sandbox
HECATEAPI_PADDLE_API_KEY=<paddle-api-key>
HECATEAPI_PADDLE_CLIENT_TOKEN=<paddle-client-token>
HECATEAPI_PADDLE_WEBHOOK_SECRET=<paddle-webhook-secret>
HECATEAPI_PADDLE_PRICE_ID_PACK_STARTER=<paddle-price-id-for-starter-pack>
HECATEAPI_PADDLE_PRICE_ID_PACK_CREATOR=<paddle-price-id-for-creator-pack>
HECATEAPI_PADDLE_PRICE_ID_PACK_PUBLISHER=<paddle-price-id-for-publisher-pack>
